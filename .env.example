# ==============================================================================
# DataForge AI - Environment Variables Template
# Copy this file to '.env' and modify as needed for local configuration.
# ==============================================================================

# Project General Settings
PROJECT_NAME="DataForge AI"
ENV="development" # development | production | test
LOG_LEVEL="INFO"  # DEBUG | INFO | WARNING | ERROR | CRITICAL

# Backend Server Configuration
BACKEND_HOST="0.0.0.0"
BACKEND_PORT=8000
API_V1_STR="/api/v1"

# Frontend Server Configuration
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Database Configuration (Docker Compose Environment)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dataforge
POSTGRES_HOST=db
POSTGRES_PORT=5432

# SQLAlchemy Connection URLs
# For Docker Compose (uses service name 'db'):
DATABASE_URL="postgresql+asyncpg://postgres:postgres@db:5432/dataforge"

# For local development outside Docker (uses localhost):
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/dataforge"

# Fallback SQLite URL (for local development without Postgres running):
# Set this as DATABASE_URL to use SQLite locally:
# DATABASE_URL="sqlite+aiosqlite:///./dataforge.db"
